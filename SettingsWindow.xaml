<Window x:Class="LeagueLogin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        Height="260" Width="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="{StaticResource BgDeep}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#FF080812">
            <TextBlock Text="SETTINGS"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource Accent}"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            <Button Style="{StaticResource WinCtrlCloseButton}"
                    Content="✕"
                    HorizontalAlignment="Right"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Close_Click"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,20,24,24">

            <TextBlock Text="STARTUP"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,10"/>

            <CheckBox x:Name="ChkStartup"
                      Content="Start League Login when Windows starts"
                      Foreground="{StaticResource TextPrimary}"
                      FontSize="12"
                      Margin="0,0,0,8"
                      Checked="ChkStartup_Changed"
                      Unchecked="ChkStartup_Changed"/>

            <CheckBox x:Name="ChkStartMinimized"
                      Content="Start minimized to tray"
                      Foreground="{StaticResource TextPrimary}"
                      FontSize="12"
                      Margin="0,0,0,20"
                      Checked="ChkStartMinimized_Changed"
                      Unchecked="ChkStartMinimized_Changed"/>

            <TextBlock Text="WINDOW"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,10"/>

            <CheckBox x:Name="ChkMinimizeOnClose"
                    Foreground="{StaticResource TextPrimary}"
                    FontSize="12"
                    Margin="0,0,0,0"
                    Checked="ChkMinimizeOnClose_Changed"
                    Unchecked="ChkMinimizeOnClose_Changed">
                <TextBlock Text="Minimize to tray instead of exiting on close" 
                        TextWrapping="Wrap"/>
            </CheckBox>

        </StackPanel>
    </Grid>
</Window>