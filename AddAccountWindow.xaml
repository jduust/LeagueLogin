<Window x:Class="LeagueLogin.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Add Account"
        Height="390" Width="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="{StaticResource BgDeep}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="LocalNeutralButton" TargetType="Button">
            <Setter Property="Background"      Value="#FF2A2A4A"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A3A5E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="#FF080812">
            <TextBlock x:Name="TitleLabel"
                       Text="ADD  ACCOUNT"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource Accent}"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            <Button Style="{StaticResource WinCtrlCloseButton}"
                    Content="✕"
                    HorizontalAlignment="Right"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Cancel_Click"/>
        </Grid>

        <!-- Form content -->
        <StackPanel Grid.Row="1" Margin="24,16,24,24">

            <TextBlock Text="Account label"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox"
                     Style="{StaticResource DarkTextBox}"
                     Margin="0,0,0,12"
                     ToolTip="Friendly name shown in the list, e.g. Main or Smurf1"/>

            <TextBlock Text="Riot username / email"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="UserBox"
                     Style="{StaticResource DarkTextBox}"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Password"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,4"/>
            <PasswordBox x:Name="PassBox"
                         Style="{StaticResource DarkPasswordBox}"
                         Margin="0,0,0,12"/>

            <TextBlock x:Name="ErrorText"
                       Foreground="#FFFF6060"
                       FontSize="11"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource LocalNeutralButton}"
                        HorizontalContentAlignment="Center"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="Save"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalContentAlignment="Center"
                        Click="Save_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
