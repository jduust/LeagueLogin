<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!--
    Build:
      wix build installer.wxs -ext WixToolset.UI.wixext -o LeagueLogin-1.0.3-x64.msi
  -->

  <Package
    Name="League Login"
    Version="1.0.3"
    Manufacturer="LeagueLogin"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine"
    InstallerVersion="500">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of League Login is already installed."
      Schedule="afterInstallInitialize"/>

    <MediaTemplate EmbedCab="yes" CompressionLevel="high"/>

    <!--
      WixUI_InstallDir: Welcome -> License -> InstallDir -> Progress -> Finish.
      No feature-tree disk icons. We inject our own OptionsDlg into the sequence.
    -->
    <ui:WixUI Id="WixUI_InstallDir"/>
    <UIRef Id="WixUI_ErrorProgressText"/>

    <!-- Custom installer graphics (BMP files in project root) -->
    <WixVariable Id="WixUILicenseRtf" Value="Assets/license.rtf"/>
    <WixVariable Id="WixUIBannerBmp"  Value="Assets/banner.bmp"/>
    <WixVariable Id="WixUIDialogBmp"  Value="Assets/dialog.bmp"/>

    <!-- Required by WixUI_InstallDir -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER"/>

    <!--
      Optional feature properties set by checkboxes in OptionsDlg.
      Default "1" = ticked. Set to "" to untick by default.
    -->
    <Property Id="INSTALL_DESKTOP" Value="1"/>
    <Property Id="INSTALL_STARTUP" Value="1"/>

    <!-- Install directory -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="LeagueLogin"/>
    </StandardDirectory>

    <!-- All published files + install folder cleanup -->
    <ComponentGroup Id="MainComponents" Directory="INSTALLFOLDER">
      <Files Include="publish\*"/>
      <Component Id="InstallFolderCleanup" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall"/>
        <RegistryValue
          Root="HKLM"
          Key="Software\LeagueLogin"
          Name="InstallPath"
          Type="string"
          Value="[INSTALLFOLDER]"
          KeyPath="yes"/>
      </Component>
    </ComponentGroup>

    <!-- Start Menu shortcut (always installed) -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="League Login">
        <Component Id="StartMenuShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
          <Shortcut
            Id="AppStartMenuShortcut"
            Name="League Login"
            Description="Switch League of Legends accounts"
            Target="[INSTALLFOLDER]LeagueLogin.exe"
            WorkingDirectory="INSTALLFOLDER"/>
          <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall"/>
          <RegistryValue
            Root="HKCU"
            Key="Software\LeagueLogin\StartMenu"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes"/>
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut — only installed when INSTALL_DESKTOP checkbox is ticked -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123"
                 Condition="INSTALL_DESKTOP = &quot;1&quot;">
        <Shortcut
          Id="AppDesktopShortcut"
          Name="League Login"
          Description="Switch League of Legends accounts"
          Target="[INSTALLFOLDER]LeagueLogin.exe"
          WorkingDirectory="INSTALLFOLDER"/>
        <RegistryValue
          Root="HKCU"
          Key="Software\LeagueLogin\Desktop"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes"/>
      </Component>
    </StandardDirectory>

    <!-- Run at Windows login — only installed when INSTALL_STARTUP checkbox is ticked -->
    <Component Id="RunOnLogin" Guid="E5F6A7B8-C9D0-1234-EF01-345678901234" Directory="INSTALLFOLDER"
               Condition="INSTALL_STARTUP = &quot;1&quot;">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="LeagueLogin"
        Type="string"
        Value="[INSTALLFOLDER]LeagueLogin.exe"
        KeyPath="yes"/>
    </Component>

    <Feature Id="MainFeature"
             Title="League Login"
             Description="The League Login application."
             Level="1">
      <ComponentGroupRef Id="MainComponents"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
      <ComponentRef Id="RunOnLogin"/>
    </Feature>

    <!--
      ── Custom Options dialog ──────────────────────────────────────────────────
      Plain checkboxes for the two optional components.
      Injected between LicenseAgreementDlg and InstallDirDlg.
    -->
    <UI>

      <Dialog Id="OptionsDlg" Width="370" Height="270"
              Title="[ProductName] Setup — Options">

        <Control Id="BannerBitmap" Type="Bitmap"
                 X="0" Y="0" Width="370" Height="44"
                 TabSkip="yes" Text="WixUI_Bmp_Banner"/>
        <Control Id="BannerLine" Type="Line"
                 X="0" Y="44" Width="370" Height="0"
                 TabSkip="yes"/>

        <Control Id="Title" Type="Text"
                 X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes" TabSkip="yes"
                 Text="{\WixUI_Font_Title}Installation Options"/>
        <Control Id="Description" Type="Text"
                 X="25" Y="24" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes" TabSkip="yes"
                 Text="Choose which optional components to install."/>

        <Control Id="DesktopCB" Type="CheckBox"
                 X="20" Y="70" Width="310" Height="17" TabSkip="no"
                 Property="INSTALL_DESKTOP" CheckBoxValue="1"
                 Text="Create a desktop shortcut"/>

        <Control Id="StartupCB" Type="CheckBox"
                 X="20" Y="95" Width="310" Height="17" TabSkip="no"
                 Property="INSTALL_STARTUP" CheckBoxValue="1"
                 Text="Start League Login automatically when Windows starts"/>

        <Control Id="BottomLine" Type="Line"
                 X="0" Y="234" Width="370" Height="0"
                 TabSkip="yes"/>

        <Control Id="Back" Type="PushButton"
                 X="180" Y="248" Width="56" Height="17" TabSkip="no" Text="&amp;Back">
          <Publish Event="NewDialog" Value="LicenseAgreementDlg" Condition="1"/>
        </Control>

        <Control Id="Next" Type="PushButton"
                 X="236" Y="248" Width="56" Height="17" TabSkip="no"
                 Default="yes" Text="&amp;Next">
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="1"/>
        </Control>

        <Control Id="Cancel" Type="PushButton"
                 X="304" Y="248" Width="56" Height="17" TabSkip="no"
                 Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1"/>
        </Control>

      </Dialog>

      <!--
        Wire OptionsDlg into the dialog sequence:
          LicenseAgreementDlg → OptionsDlg → InstallDirDlg
      -->
      <Publish Dialog="LicenseAgreementDlg" Control="Next"
               Event="NewDialog" Value="OptionsDlg" Order="3"
               Condition="LicenseAccepted = &quot;1&quot;"/>

      <Publish Dialog="InstallDirDlg" Control="Back"
               Event="NewDialog" Value="OptionsDlg" Condition="1"/>

    </UI>

  </Package>
</Wix>
