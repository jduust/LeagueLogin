<Window x:Class="LeagueLogin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="League Login"
        Width="360"
        MinHeight="260" MinWidth="320"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeep}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>  <!-- custom title bar -->
            <RowDefinition Height="*"/>   <!-- content          -->
        </Grid.RowDefinitions>

        <!-- ── Custom title bar ──────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#FF080812">

            <!-- App name (also acts as the drag handle via CaptionHeight) -->
            <TextBlock Text="LEAGUE  LOGIN"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource Accent}"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>

            <!-- Window control buttons — must opt-in to hit-testing -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource WinCtrlButton}"
                        Content="⚙"
                        ToolTip="Settings"
                        FontSize="14"
                        Click="WinSettings_Click"/>
                <Button Style="{StaticResource WinCtrlButton}"
                        Content="─"
                        ToolTip="Minimize"
                        Click="WinMin_Click"/>
                <Button x:Name="MaxRestoreBtn"
                        Style="{StaticResource WinCtrlButton}"
                        Content="□"
                        ToolTip="Maximize"
                        Click="WinMaxRestore_Click"/>
                <Button Style="{StaticResource WinCtrlCloseButton}"
                        Content="✕"
                        ToolTip="Close"
                        Click="WinClose_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── Main content ──────────────────────────────────────── -->
        <Grid Grid.Row="1" x:Name="ContentGrid" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- update banner   -->
                <RowDefinition Height="Auto"/> <!-- header          -->
                <RowDefinition Height="*"/>    <!-- account list    -->
                <RowDefinition Height="Auto"/> <!-- status bar      -->
            </Grid.RowDefinitions>

            <!-- Update banner (collapsed by default; populated by Updater check) -->
            <Border x:Name="UpdateBanner"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    Background="#FF1F1A2E"
                    BorderBrush="{StaticResource Accent}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="UpdateBannerTitle"
                               Text="Update available"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock x:Name="UpdateBannerSubtitle"
                               Text=""
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="UpdateSkipBtn"
                                Style="{StaticResource NeutralButtonStyle}"
                                Padding="10,5" FontSize="11"
                                Margin="0,0,6,0"
                                Click="UpdateSkip_Click">
                            <TextBlock Text="Skip this version" Foreground="{StaticResource TextPrimary}"/>
                        </Button>
                        <Button x:Name="UpdateNotesBtn"
                                Style="{StaticResource NeutralButtonStyle}"
                                Padding="10,5" FontSize="11"
                                Margin="0,0,6,0"
                                Click="UpdateNotes_Click">
                            <TextBlock Text="Release notes" Foreground="{StaticResource TextPrimary}"/>
                        </Button>
                        <Button x:Name="UpdateInstallBtn"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="10,5" FontSize="11"
                                Click="UpdateInstall_Click">
                            <TextBlock x:Name="UpdateInstallText" Text="Download &amp; install"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Header -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Select an account to launch"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource NeutralButtonStyle}"
                        VerticalAlignment="Center"
                        Padding="10,6"
                        Click="AddAccount_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" Account" FontSize="12"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Bottom"
                       Fill="#FF2A2A4A" Margin="0,0,0,-4"/>

            <!-- Account list -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,8,0,8">
                <StackPanel x:Name="AccountPanel">
                    <TextBlock x:Name="EmptyLabel"
                               Text="No accounts yet. Click '+ Account' to add one."
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="3"
                    Background="#FF0A0A18"
                    CornerRadius="4"
                    Padding="10,6"
                    Margin="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="Ready"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Ellipse x:Name="Spinner"
                             Grid.Column="1"
                             Width="8" Height="8"
                             Margin="8,0,0,0"
                             Fill="{StaticResource Accent}"
                             Visibility="Collapsed">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="4" CenterY="4"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>
            </Border>
        </Grid>

        <!-- Resize grip (bottom-right corner) -->
        <ResizeGrip Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Foreground="{StaticResource TextMuted}"
                    Opacity="0.35"/>
    </Grid>
</Window>
